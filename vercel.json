{
  "version": 2,
  "framework": null,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/(.*\\.(?:css|js|ico|png|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|eot|mp3|mp4|webm|pdf|txt|xml|json))$",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "outputDirectory": "public"
}